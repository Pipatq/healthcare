# =============================================================================
# HIS-to-HIS Environment Variables
# Copy this file to .env and fill in production values. Never commit .env.
# =============================================================================

# --- Shared ------------------------------------------------------------------
ENV=dev
POSTGRES_PASSWORD=postgres

# --- Security Keys (CHANGE IN PRODUCTION!) -----------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# Pre-shared key: FHIR Gateway → HIS B Facade
HIS_B_API_KEY=his-b-secret-key

# Pre-shared key: HIS A Backend → FHIR Gateway
GATEWAY_API_KEY=gateway-secret-key

# JWT secret for doctor authentication in HIS A
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# --- Frontend (Vite local dev only) ------------------------------------------
# Docker: leave empty — nginx proxies /api/ to his_a_backend automatically.
# Local dev (outside Docker): set to http://localhost:8000
VITE_API_BASE_URL=
