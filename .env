# =============================================================================
# HIS-to-HIS Local Dev Environment
# =============================================================================

ENV=dev
POSTGRES_PASSWORD=postgres

# Pre-shared key: FHIR Gateway → HIS B Facade
HIS_B_API_KEY=his-b-secret-key

# Pre-shared key: HIS A Backend → FHIR Gateway
GATEWAY_API_KEY=gateway-secret-key

# JWT secret for HIS A doctor auth
JWT_SECRET_KEY=dev-jwt-secret-key-not-for-production

# Frontend local dev
VITE_API_BASE_URL=http://localhost:8000
